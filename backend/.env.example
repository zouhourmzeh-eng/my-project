DATABASE_URL=postgresql+asyncpg://postgres:1234@localhost:5432/qms_db
SECRET_KEY=your_super_secret_key_here
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:5173
# S3 / R2 configuration
S3_BUCKET=qms-documents
S3_REGION=auto
S3_ACCESS_KEY=your-access-key
S3_SECRET_KEY=your-secret-key
S3_ENDPOINT_URL=https://<account>.r2.cloudflarestorage.com
S3_PUBLIC_URL=https://pub-xxxx.r2.dev

# SMTP Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=abcdefghijklmnop  <-- Collez ici le code de 16 caractères (sans les espaces si possible, ou avec, Gmail accepte les deux)
SMTP_FROM=your-email@gmail.com

OPENAI_API_KEY=your-openai-api-key
